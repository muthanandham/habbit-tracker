# Server Configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/life-os
JWT_SECRET=your_secure_secret_key

# AI Provider Configuration
# Set to 'huggingface' or 'gemini'. Defaults to 'gemini' unless HF_TOKEN is present.
AI_PROVIDER=huggingface

# Hugging Face Configuration
HF_TOKEN=your_huggingface_token
# Optional: Specify a model supported by the HF Inference API router
# HF_MODEL=openai/gpt-oss-120b:fastest

# Gemini Configuration (Optional fallback)
# GEMINI_API_KEY=your_gemini_api_key
